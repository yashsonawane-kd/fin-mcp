# Keycloak auth server (run via: docker compose up)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=fin-mcp

# This must match the clientId of the bearer-only client in realm-export.json
RESOURCE_SERVER_CLIENT_ID=mcp-resource-server

# Public URL of this MCP server (used in WWW-Authenticate and metadata response)
MCP_SERVER_URL=http://localhost:3000

# Host and port for the MCP server
# Use 127.0.0.1 for local dev, 0.0.0.0 when running inside Docker
MCP_HOST=127.0.0.1
MCP_PORT=3000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Redis (run via: docker compose up)
REDIS_URL=redis://localhost:6379/0

# Rate limits (calls per hour per tier)
RATE_LIMIT_FREE=30
RATE_LIMIT_PREMIUM=150
RATE_LIMIT_ANALYST=500

# Upstream API keys
ALPHA_VANTAGE_API_KEY=your_key_here   # https://www.alphavantage.co/support/#api-key
FINNHUB_API_KEY=your_key_here         # https://finnhub.io/register
NEWSAPI_API_KEY=your_key_here         # https://newsapi.org/register
